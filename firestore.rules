rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────
    function authed() {
      return request.auth != null;
    }
    function myData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    function myRol() {
      return myData().rol;
    }
    function myOrgId() {
      return myData().orgId;
    }
    function myClinicaId() {
      return myData().clinicaActiva != null ? myData().clinicaActiva : myData().clinicaId;
    }

    // Pertenece a esta clínica (por clinicaId o por orgId siendo owner/director)
    function belongsToClinica(clinicaId) {
      return authed() && (
        myClinicaId() == clinicaId ||
        (myRol() == 'owner'    && myOrgId() == get(/databases/$(database)/documents/clinicas/$(clinicaId)).data.orgId) ||
        (myRol() == 'director' && clinicaId in myData().sucursales)
      );
    }

    // Es admin o superior de esta clínica
    function isAdminOf(clinicaId) {
      return authed() && (
        myRol() == 'owner'    ||
        myRol() == 'director' ||
        (myRol() == 'admin' && myClinicaId() == clinicaId)
      );
    }

    // Es owner de la organización
    function isOwnerOfOrg(orgId) {
      return authed() && myRol() == 'owner' && myOrgId() == orgId;
    }

    // ── Organizaciones ──────────────────────────────────────────
    match /organizaciones/{orgId} {
      allow read:   if authed() && myOrgId() == orgId;
      allow create: if authed();
      allow update: if isOwnerOfOrg(orgId);
      allow delete: if isOwnerOfOrg(orgId);
    }

    // ── Usuarios ───────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read:   if authed();
      allow create: if authed() && (request.auth.uid == uid || myRol() == 'admin' || myRol() == 'owner');
      allow update: if authed() && (request.auth.uid == uid || myRol() == 'admin' || myRol() == 'owner' || myRol() == 'director');
      allow delete: if authed() && (myRol() == 'admin' || myRol() == 'owner');
    }

    // ── Clínicas ───────────────────────────────────────────────
    match /clinicas/{clinicaId} {
      allow read:   if belongsToClinica(clinicaId);
      allow create: if authed();
      allow update: if belongsToClinica(clinicaId);
      allow delete: if isAdminOf(clinicaId) || isOwnerOfOrg(resource.data.orgId);

      // Sub-colecciones (pacientes, citas, etc.) — igual que antes
      match /{collection}/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /{col1}/{doc1}/{col2}/{doc2} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /{col1}/{doc1}/{col2}/{doc2}/{col3}/{doc3} {
        allow read, write: if belongsToClinica(clinicaId);
      }
    }

    // ── Globales ───────────────────────────────────────────────
    match /_calificaciones_globales/{docId} {
      allow create: if authed();
      allow read:   if false;
    }
    match /_mensajes_soporte/{docId} {
      allow create: if authed();
      allow read:   if false;
    }
  }
}
