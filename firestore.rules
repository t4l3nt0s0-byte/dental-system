rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────
    function belongsToClinica(clinicaId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.clinicaId == clinicaId;
    }
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }
    function isAdminOf(clinicaId) {
      return belongsToClinica(clinicaId) && isAdmin();
    }

    // ── Usuarios ──────────────────────────────────────────────
    // Crear: propio uid ó admin autenticado (para que admin pueda crear usuarios)
    match /usuarios/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
                       (request.auth.uid == uid || isAdmin());
      allow update: if request.auth != null &&
                       (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Clínicas ──────────────────────────────────────────────
    // Crear clínica: solo el admin recién creado puede crear la suya
    match /clinicas/{clinicaId} {
      allow read:   if belongsToClinica(clinicaId);
      allow create: if request.auth != null;  // alta inicial de registro
      allow update: if belongsToClinica(clinicaId);
      allow delete: if isAdminOf(clinicaId);

      // Todas las subcolecciones: pacientes, citas, tratamientos, etc.
      match /{collection}/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /{col1}/{doc1}/{col2}/{doc2} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /{col1}/{doc1}/{col2}/{doc2}/{col3}/{doc3} {
        allow read, write: if belongsToClinica(clinicaId);
      }
    }

    // ── Globales ──────────────────────────────────────────────
    match /_calificaciones_globales/{docId} {
      allow create: if request.auth != null;
      allow read:   if false;
    }
    match /_mensajes_soporte/{docId} {
      allow create: if request.auth != null;
      allow read:   if false;
    }
  }
}
