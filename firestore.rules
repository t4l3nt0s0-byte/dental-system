rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    // HERSANTYCH — FIRESTORE RULES v4.0 (SIMPLIFIED)
    // Regla principal: cualquier usuario autenticado puede
    // leer/escribir en su organización.
    // Las validaciones complejas van en el backend (Cloud Functions).
    // ══════════════════════════════════════════════════════════

    function authed() {
      return request.auth != null;
    }

    // Cualquier usuario autenticado tiene acceso
    // La seguridad real viene de que solo conocen su orgId
    // (obtenido de su documento en usuarios/)

    // ── Colección global de usuarios ────────────────────────
    match /usuarios/{userId} {
      allow read:   if authed();
      allow create: if authed();
      allow update: if authed() && request.auth.uid == userId;
      allow delete: if authed() && request.auth.uid == userId;
    }

    // ── Organizaciones ──────────────────────────────────────
    match /organizations/{orgId} {
      allow read, write: if authed();

      match /{collection}/{docId} {
        allow read, write: if authed();

        match /{subCollection}/{subDocId} {
          allow read, write: if authed();

          match /{deepCollection}/{deepDocId} {
            allow read, write: if authed();
          }
        }
      }
    }

    // ── Clínicas (legado — durante migración) ───────────────
    match /clinicas/{clinicaId} {
      allow read, write: if authed();

      match /{collection}/{docId} {
        allow read, write: if authed();
      }
    }

    // ── Tokens públicos (portal paciente) ───────────────────
    match /_tokens/{tokenId} {
      allow read:          if true;
      allow create, delete: if authed();
    }

    // ── Solicitudes públicas ─────────────────────────────────
    match /solicitudes/{docId} {
      allow read, create: if true;
      allow update, delete: if authed();
    }
  }
}
