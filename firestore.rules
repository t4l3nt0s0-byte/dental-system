rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────
    // IMPORTANTE: máximo 1 get() por evaluación de regla en Firestore.
    // Toda la lógica de pertenencia se basa en campos del doc del usuario,
    // sin get() adicionales encadenados.

    function authed() {
      return request.auth != null;
    }

    // Leer doc del usuario autenticado (1 get() máximo por regla)
    function myData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // El usuario pertenece a esta clínica si:
    //   a) su clinicaId o clinicaActiva coincide, O
    //   b) su orgId coincide (owner con acceso a todo el grupo)
    //   c) es director y la clínica está en su lista de sucursales
    function belongsToClinica(clinicaId) {
      let d = myData();
      return authed() && (
        d.clinicaId     == clinicaId ||
        d.clinicaActiva == clinicaId ||
        d.orgId         == clinicaId
      );
    }

    // Admin o superior de la clínica
    function isAdminOf(clinicaId) {
      let d = myData();
      return authed() && (
        d.rol == 'owner'                           ||
        d.rol == 'director'                        ||
        (d.rol == 'admin' && (
          d.clinicaId     == clinicaId ||
          d.clinicaActiva == clinicaId ||
          d.orgId         == clinicaId
        ))
      );
    }

    // ── Organizaciones ───────────────────────────────────────────
    match /organizaciones/{orgId} {
      allow read, write: if authed() && myData().orgId == orgId;
    }

    // ── Usuarios ────────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read:   if authed();
      allow create: if authed() && (
        request.auth.uid == uid ||
        myData().rol == 'admin' ||
        myData().rol == 'owner'
      );
      allow update: if authed() && (
        request.auth.uid == uid ||
        myData().rol == 'admin' ||
        myData().rol == 'owner' ||
        myData().rol == 'director'
      );
      allow delete: if authed() && (
        myData().rol == 'admin' ||
        myData().rol == 'owner'
      );
    }

    // ── Clínicas ─────────────────────────────────────────────────
    match /clinicas/{clinicaId} {
      allow read:   if belongsToClinica(clinicaId);
      allow create: if authed();
      allow update: if belongsToClinica(clinicaId);
      allow delete: if isAdminOf(clinicaId);

      // Sub-colecciones: pacientes, citas, tratamientos, etc.
      match /{col}/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /{col1}/{doc1}/{col2}/{doc2} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /{col1}/{doc1}/{col2}/{doc2}/{col3}/{doc3} {
        allow read, write: if belongsToClinica(clinicaId);
      }
    }

    // ── Globales ─────────────────────────────────────────────────
    match /_calificaciones_globales/{docId} {
      allow create: if authed();
      allow read:   if false;
    }
    match /_mensajes_soporte/{docId} {
      allow create: if authed();
      allow read:   if false;
    }
  }
}
