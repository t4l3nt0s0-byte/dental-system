rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Verifica que el usuario pertenece a la clínica
    function belongsToClinica(clinicaId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.clinicaId == clinicaId;
    }

    // ── Verifica si el usuario es admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    // ── Usuarios: cada quien lee/edita el suyo, admin lee todos
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Clínica: solo miembros de esa clínica
    match /clinicas/{clinicaId} {
      allow read, write: if belongsToClinica(clinicaId);

      // ── COMODÍN: cubre TODAS las subcolecciones de 1 nivel
      // pacientes, tratamientos, abonos, citas, catalogo,
      // cotizaciones, cortes, inventario, ofertas, rx,
      // notas-clinicas, recibos, plantillas, recordatorios, etc.
      match /{collection}/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }

      // ── COMODÍN: cubre subcolecciones anidadas de 2 niveles
      // odontogramas/{pacienteId}/historial/{histId}
      match /{col1}/{doc1}/{col2}/{doc2} {
        allow read, write: if belongsToClinica(clinicaId);
      }

      // ── COMODÍN: cubre subcolecciones anidadas de 3 niveles
      // por si acaso en el futuro
      match /{col1}/{doc1}/{col2}/{doc2}/{col3}/{doc3} {
        allow read, write: if belongsToClinica(clinicaId);
      }
    }

    // Calificaciones globales (solo escritura de usuarios autenticados)
    match /_calificaciones_globales/{docId} {
      allow create: if request.auth != null;
      allow read: if false; // Solo Hersantych lee desde Console
    }

    // Mensajes de soporte (solo escritura de usuarios autenticados)
    match /_mensajes_soporte/{docId} {
      allow create: if request.auth != null;
      allow read: if false; // Solo Hersantych lee desde Console
    }
  }
}
