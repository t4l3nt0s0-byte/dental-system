rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // DENTALOS — RBAC COMPLETO
    // Roles: owner > director > admin > doctor > recepcion > asistente
    // Un solo get() por evaluación — sin get() anidados
    // ═══════════════════════════════════════════════════════════

    function authed() {
      return request.auth != null;
    }

    // Leer doc del usuario actual (1 get() por regla — límite de Firestore)
    function me() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // ── Helpers de rol ─────────────────────────────────────────
    function isOwner()    { return authed() && me().rol == 'owner'; }
    function isDirector() { return authed() && me().rol == 'director'; }
    function isAdmin()    { return authed() && me().rol == 'admin'; }
    function isDoctor()   { return authed() && me().rol == 'doctor'; }
    function isSuperUser(){ return authed() && (me().rol == 'owner' || me().rol == 'director' || me().rol == 'admin'); }

    // ── Pertenencia a clínica ──────────────────────────────────
    // Sin get() anidado — usa campos del doc del usuario directamente
    function belongsToClinica(clinicaId) {
      let d = me();
      return authed() && (
        d.clinicaId     == clinicaId ||   // clínica base
        d.clinicaActiva == clinicaId ||   // clínica activa (multi-sucursal)
        d.orgId         == clinicaId      // propietario del org (orgId = clinicaId raíz)
      );
    }

    // ── Puede administrar esta clínica ──────────────────────────
    function canAdminClinica(clinicaId) {
      let d = me();
      return authed() && (
        d.rol == 'owner' ||
        d.rol == 'director' ||
        (d.rol == 'admin' && (d.clinicaId == clinicaId || d.clinicaActiva == clinicaId))
      );
    }

    // ══════════════════════════════════════════════════════════
    // COLECCIONES GLOBALES
    // ══════════════════════════════════════════════════════════

    // ── Usuarios ───────────────────────────────────────────────
    // Lectura: cualquier usuario autenticado puede leer (para el selector de doctores, etc.)
    // Escritura: solo admin+ puede crear/editar/eliminar
    match /usuarios/{uid} {
      allow read:   if authed();
      allow create: if authed() && (
        request.auth.uid == uid ||   // auto-registro
        isSuperUser()                // admin+ crea empleados
      );
      allow update: if authed() && (
        request.auth.uid == uid ||   // propio perfil
        isSuperUser()                // admin+ edita
      );
      allow delete: if isSuperUser();
    }

    // ── Organizaciones ──────────────────────────────────────────
    match /organizaciones/{orgId} {
      allow read:   if authed() && me().orgId == orgId;
      allow write:  if isOwner() && me().orgId == orgId;
    }

    // ── Tokens del portal del paciente ─────────────────────────
    match /_tokens/{tokenId} {
      allow read:   if true;  // público — el token ya es la autenticación
      allow create: if authed();
      allow delete: if authed();
    }

    // ── Global anónimo ──────────────────────────────────────────
    match /_calificaciones_globales/{docId} {
      allow create: if authed();
      allow read:   if false;
    }

    // ══════════════════════════════════════════════════════════
    // CLÍNICAS — datos multi-nivel
    // ══════════════════════════════════════════════════════════
    match /clinicas/{clinicaId} {

      // Doc de la clínica: leer si pertenece, editar si es admin+
      allow read:   if belongsToClinica(clinicaId);
      allow create: if authed();
      allow update: if canAdminClinica(clinicaId);
      allow delete: if isOwner();

      // ── Sub-colecciones operativas ─────────────────────────
      // Todos los miembros de la clínica pueden leer y escribir
      match /pacientes/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /citas/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /tratamientos/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /abonos/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /cotizaciones/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /catalogo/{docId} {
        allow read:  if belongsToClinica(clinicaId);
        allow write: if canAdminClinica(clinicaId);
      }
      match /doctores/{docId} {
        allow read:  if belongsToClinica(clinicaId);
        allow write: if canAdminClinica(clinicaId);
      }

      // ── Sub-colecciones clínicas ───────────────────────────
      match /odontogramas/{pxId} {
        allow read, write: if belongsToClinica(clinicaId);
        match /historial/{hId} {
          allow read, write: if belongsToClinica(clinicaId);
        }
      }
      match /rx/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /recetas/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /notas-clinicas/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }

      // ── Sub-colecciones financieras ────────────────────────
      match /cortes/{docId} {
        allow read:  if belongsToClinica(clinicaId);
        allow write: if canAdminClinica(clinicaId);
      }
      match /recibos/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
      match /inventario/{docId} {
        allow read:  if belongsToClinica(clinicaId);
        allow write: if canAdminClinica(clinicaId);
      }
      match /ofertas/{docId} {
        allow read:  if belongsToClinica(clinicaId);
        allow write: if canAdminClinica(clinicaId);
      }

      // ── Sub-colecciones del sistema (admin+ solo) ──────────
      match /apiKeys/{keyId} {
        allow read, write: if canAdminClinica(clinicaId);
      }
      match /auditoria/{docId} {
        allow read:   if canAdminClinica(clinicaId);
        allow create: if belongsToClinica(clinicaId); // cualquiera puede generar eventos
        allow update, delete: if false; // inmutables
      }
      match /backups/{backupId} {
        allow read:   if canAdminClinica(clinicaId);
        allow create: if belongsToClinica(clinicaId);
        allow update, delete: if false; // inmutables
      }
      match /tokens/{tokenId} {
        allow read, write: if canAdminClinica(clinicaId);
      }

      // ── Fallback para otras subcolecciones ─────────────────
      match /{collection}/{docId} {
        allow read, write: if belongsToClinica(clinicaId);
      }
    }
  }
}
